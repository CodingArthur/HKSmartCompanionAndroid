    <string name="settings_data_source_title">Data source mode</string>
    <string name="settings_mode_auto">Auto fallback</string>
    <string name="settings_mode_auto_desc">Try official live data first, then fall back to built-in demo recommendations if the network or source fails.</string>
    <string name="settings_mode_demo">Demo only</string>
    <string name="settings_mode_demo_desc">Use local sample data for predictable demos without any live-network dependency.</string>
    <string name="settings_mode_official">Official data only</string>
    <string name="settings_mode_official_desc">Fetch directly from official HA, data.gov.hk, and HKTB sources. Fail instead of falling back when live requests break.</string>
