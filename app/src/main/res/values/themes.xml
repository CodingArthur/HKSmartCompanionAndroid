<resources>
    <style name="Base.Theme.HKSmartCompanionAndroid" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="colorPrimary">@color/brand_primary</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorPrimaryContainer">@color/brand_surface_alt</item>
        <item name="colorOnPrimaryContainer">@color/brand_text</item>
        <item name="colorSecondary">@color/brand_secondary</item>
        <item name="colorOnSecondary">@color/brand_text</item>
        <item name="colorSurface">@color/white</item>
        <item name="android:colorBackground">@color/brand_surface</item>
        <item name="android:statusBarColor">@color/brand_primary_dark</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Widget.HKSmartCompanion.CompactDropdown" parent="Widget.Material3.TextInputLayout.OutlinedBox.ExposedDropdownMenu">
        <item name="android:minHeight">48dp</item>
        <item name="boxStrokeWidth">1dp</item>
        <item name="boxStrokeWidthFocused">1dp</item>
        <item name="boxCollapsedPaddingTop">6dp</item>
    </style>

    <style name="Theme.HKSmartCompanionAndroid" parent="Base.Theme.HKSmartCompanionAndroid" />
</resources>
